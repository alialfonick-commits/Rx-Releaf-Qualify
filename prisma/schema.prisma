generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  phone     String?
  role      Role
  staffNumber  Int?     @unique
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  lastLogin DateTime?

  createdAt DateTime @default(now())

  exams     Exam[]
}

model Patient {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  dob       DateTime
  createdAt DateTime @default(now())
  birthSex  BirthSex
  email     String
  phone     String
  exams     Exam[]
}

model Exam {
  id               String           @id @default(uuid())
  caseNumber       Int @unique @default(autoincrement())
  patientId        String
  staffId          String?
  createdAt        DateTime         @default(now())
  consultationType ConsultationType
  patientState     String
  paymentId        String?
  paymentLink      String?
  paymentStatus    PaymentStatus
  examId           Int
  examName         String
  isPhoneVisit     Boolean          @default(false)
  providerName     String?
  status           ExamStatus       @default(PENDING)
  updatedAt        DateTime         @updatedAt
  patient          Patient          @relation(fields: [patientId], references: [id])
  staff            User?            @relation(fields: [staffId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  timestamp DateTime @default(now())
  ipAddress String?
}

enum Role {
  ADMIN
  STAFF
}

enum BirthSex {
  MALE
  FEMALE
}

enum ConsultationType {
  URGENT_CARE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ExamStatus {
  PENDING
  INVITED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
