generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  name        String?
  email       String    @unique
  password    String
  phone       String?
  role        Role
  staffNumber Int?      @unique
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  lastLogin   DateTime?

  createdAt DateTime @default(now())

  exams Exam[]

  sessions Session[]
  mfaChallenges MfaChallenge[]
}

model ConsultationTypeSetting {
  id          String   @id @default(uuid())
  typeKey     String   @unique
  label       String
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  options     ConsultationOptionSetting[]
}

model ConsultationOptionSetting {
  id                String   @id @default(uuid())
  consultationTypeId String
  qualiphyExamId    Int
  title             String
  rxType            Int?
  isEnabled         Boolean  @default(true)
  sortOrder         Int      @default(0)
  rawData           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  consultationType  ConsultationTypeSetting @relation(fields: [consultationTypeId], references: [id], onDelete: Cascade)

  @@unique([consultationTypeId, qualiphyExamId])
  @@index([qualiphyExamId])
}

model Patient {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  dob       DateTime
  createdAt DateTime @default(now())
  birthSex  BirthSex
  email     String
  phone     String
  exams     Exam[]
}

model Exam {
  id               String           @id @default(uuid())
  caseNumber       Int              @unique @default(autoincrement())
  patientId        String
  staffId          String?
  createdAt        DateTime         @default(now())
  consultationType ConsultationType
  patientState     String
  paymentId        String?
  paymentLink      String?
  paymentStatus    PaymentStatus
  examId           Int
  examName         String
  isPhoneVisit     Boolean          @default(false)
  providerName     String?
  status           ExamStatus       @default(PENDING)
  updatedAt        DateTime         @updatedAt
  patient          Patient          @relation(fields: [patientId], references: [id])
  staff            User?            @relation(fields: [staffId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  timestamp DateTime @default(now())
  ipAddress String?
}

model MfaChallenge {
  id         String    @id @default(uuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

enum Role {
  ADMIN
  STAFF
}

enum BirthSex {
  MALE
  FEMALE
}

enum ConsultationType {
  URGENT_CARE
  GOOD_FAITH
  QUALIPHY_RX
  CHOOSE_PHARMACY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ExamStatus {
  PENDING
  INVITED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
